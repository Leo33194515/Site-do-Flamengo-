<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<title>Site Flamengo</title>

<style>
body{
  margin:0;
  font-family: Arial;
  background: linear-gradient(180deg, #a00000, #000);
  color:white;
  text-align:center;
}

header{
  padding:20px;
  font-size:24px;
  font-weight:bold;
}

.chat{
  position:fixed;
  bottom:20px;
  right:20px;
  width:250px;
  background:#111;
  border-radius:10px;
  padding:10px;
}

.messages{
  height:150px;
  overflow-y:auto;
  text-align:left;
  font-size:14px;
}

input{
  width:100%;
  padding:5px;
  margin-top:5px;
}
</style>
</head>

<body>

<header>🔥 Site Flamengo 🔴⚫</header>

<h1>Bem-vindo ao site do Flamengo!</h1>
<p>O maior clube do Brasil 🇧🇷</p>

<div class="chat">
  <div class="messages" id="chat"></div>
  <input type="text" id="msg" placeholder="Digite..." onkeypress="responder(event)">
</div>

<script>
function responder(e){
  if(e.key === "Enter"){
    let input = document.getElementById("msg");
    let chat = document.getElementById("chat");

    let userMsg = input.value;
    chat.innerHTML += "<p><b>Você:</b> " + userMsg + "</p>";

    let resposta = "Sou o chat do Mengão 🔴⚫";

    if(userMsg.toLowerCase().includes("oi")) resposta = "Salve Nação! 🔥";
    if(userMsg.toLowerCase().includes("título")) resposta = "Temos vários! Libertadores, Brasileirão 😎";
    if(userMsg.toLowerCase().includes("jogo")) resposta = "Hoje tem Mengão em campo!";

    setTimeout(()=>{
      chat.innerHTML += "<p><b>Bot:</b> " + resposta + "</p>";
      chat.scrollTop = chat.scrollHeight;
    },500);

    input.value="";
  }
}
</script>

</body>
</html>
